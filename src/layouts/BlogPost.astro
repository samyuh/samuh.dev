---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags = [], readingTime = 1, relatedPosts = [] } = Astro.props;

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	keywords: tags.join(', '),
	author: {
		'@type': 'Person',
		name: 'Diogo Samuel Fernandes',
		url: 'https://samuh.dev/'
	}
};
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage ?? '/og-default.svg'}
			type="article"
			publishedTime={pubDate.toISOString()}
			modifiedTime={(updatedDate ?? pubDate).toISOString()}
			tags={tags}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<a href="/blog" class="breadcrumb">← Blog</a>
				{heroImage && (
					<div class="hero-image">
						<img src={heroImage} alt="" />
					</div>
				)}
				<div class="post-header">
					<div class="post-meta">
						<FormattedDate date={pubDate} />
						<span aria-hidden="true">·</span>
						<span>{readingTime} min read</span>
						{updatedDate && (
							<span class="updated">
								&middot; Updated <FormattedDate date={updatedDate} />
							</span>
						)}
					</div>
					<h1>{title}</h1>
					{description && <p class="post-description">{description}</p>}
					{tags.length > 0 && (
						<ul class="tags" aria-label="Post tags">
							{tags.map((tag: string) => <li>#{tag}</li>)}
						</ul>
					)}
				</div>
				<div class="prose">
					<slot />
				</div>

				<section class="author-box" aria-label="About the author">
					<p>
						Samuel Fernandes is a Software Engineer at Feedzai, working on real-time payment fraud
						detection systems. His focus is on reliability, scalability, and cost-efficient
						infrastructure for production ML workloads, with hands-on development across backend
						services and platform tooling.
					</p>
				</section>

				{relatedPosts.length > 0 && (
					<section class="related-posts" aria-label="Related posts">
						<ul>
							{relatedPosts.map((related: CollectionEntry<'blog'>) => (
								<li>
									<a href={`/blog/${related.slug}/`}>
										<span>{related.data.title}</span>
										<small>
											<FormattedDate date={related.data.pubDate} />
										</small>
									</a>
								</li>
							))}
						</ul>
					</section>
				)}
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.breadcrumb {
		display: inline-block;
		font-size: 0.875rem;
		color: var(--text-muted);
		text-decoration: none;
		margin-bottom: 2.25em;
		transition: color 0.18s;
	}
	.breadcrumb:hover { color: var(--accent); }
	.hero-image {
		margin-bottom: 2em;
	}
	.hero-image img {
		width: 100%;
		border-radius: 12px;
	}
	.post-header {
		max-width: 820px;
		margin-bottom: 2.25em;
		padding-bottom: 2em;
		border-bottom: 1px solid var(--border);
	}
	.post-header h1 {
		font-size: 2.35em;
		margin: 0.25em 0 0;
		line-height: 1.15;
		letter-spacing: -0.02em;
	}
	.post-meta {
		color: var(--text-muted);
		font-size: 0.875rem;
		display: flex;
		align-items: center;
		gap: 0.4em;
		margin-bottom: 0.25em;
		flex-wrap: wrap;
	}
	.updated { font-style: italic; }
	.post-description {
		margin: 0.6em 0 0;
		font-size: 1.04rem;
		color: var(--text-muted);
		line-height: 1.65;
		max-width: 680px;
	}
	.tags {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		margin: 1em 0 0;
		padding: 0;
	}
	.tags li {
		font-size: 0.8rem;
		padding: 0.2em 0.6em;
		border: 1px solid var(--border-light);
		border-radius: 999px;
		color: var(--text-muted);
	}
	.prose {
		max-width: 820px;
		font-size: 1.09rem;
		line-height: 1.78;
		color: var(--text-heading);
	}
	.prose :global(p),
	.prose :global(li) {
		color: var(--text-heading);
	}
	.author-box,
	.related-posts {
		max-width: 820px;
		margin-top: 2.6em;
		padding-top: 1.25em;
		border-top: 1px solid var(--border);
		opacity: 0.72;
	}
	.author-box p {
		margin: 0;
		color: var(--text-muted);
		font-size: 0.88rem;
		line-height: 1.7;
	}
	.related-posts ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.9em;
	}
	.related-posts a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1em;
		color: var(--text-muted);
		font-size: 0.9rem;
	}
	.related-posts a:hover {
		color: var(--accent);
	}
	.related-posts small {
		color: var(--text-muted);
		font-size: 0.8rem;
	}
</style>
