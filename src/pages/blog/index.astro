---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog'))
	.filter((post) => post.data.listed !== false)
	.sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
	);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Blog</h1>
			<ul class="posts-list">
				{
					posts.map((post) => {
						const words = post.body.split(/\s+/).filter(Boolean).length;
						const readingTime = Math.max(1, Math.ceil(words / 220));
						return (
						<li>
							<a href={`/blog/${post.slug}/`} class="post-row">
								<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
								<span class="post-body">
									<span class="post-title">{post.data.title}</span>
									<span class="post-desc">{post.data.description}</span>
									<span class="post-meta-extra">
										{readingTime} min read
										{post.data.tags.length > 0 && (
											<>
												<span aria-hidden="true"> · </span>
												{post.data.tags.slice(0, 3).map((tag, idx) => (
													<span>{idx > 0 ? ` #${tag}` : `#${tag}`}</span>
												))}
											</>
										)}
									</span>
								</span>
								<span class="post-arrow">→</span>
							</a>
						</li>
						);
					})
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 { margin-bottom: 1.5em; }
	.post-meta-extra {
		font-size: 0.8rem;
		color: var(--text-muted);
	}
</style>
