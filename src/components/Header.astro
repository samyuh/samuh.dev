---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo">
			<span class="logo-name">samuh</span><span class="logo-tld">.dev</span>
		</a>
		<div class="nav-links">
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/contact">Let's Talk</HeaderLink>
			<button id="theme-toggle" aria-label="Toggle light/dark theme" title="Toggle theme">
				<svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<circle cx="12" cy="12" r="4"/>
					<line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/>
					<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
					<line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/>
					<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
				</svg>
				<svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none">
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
				</svg>
			</button>
		</div>
	</nav>
</header>
<style>
	header {
		width: 1100px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 1.75em 2em;
	}
	nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.logo {
		text-decoration: none;
		line-height: 1;
		display: flex;
		align-items: baseline;
		gap: 0;
	}
	.logo-name {
		font-weight: 700;
		font-size: 1.15rem;
		color: var(--text-heading);
		letter-spacing: -0.03em;
		transition: color 0.2s;
	}
	.logo-tld {
		font-weight: 400;
		font-size: 1.15rem;
		color: var(--accent);
		letter-spacing: -0.03em;
		transition: color 0.2s;
	}
	.logo:hover .logo-name { color: var(--accent); }
	.logo:hover .logo-tld  { color: var(--accent-hover); }
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}
	#theme-toggle {
		background: none;
		border: none;
		cursor: pointer;
		color: var(--text-muted);
		padding: 0.35em 0.5em;
		display: flex;
		align-items: center;
		transition: color 0.18s;
		margin-left: 0.25em;
	}
	#theme-toggle:hover { color: var(--text-heading); }
</style>
<script>
	const toggle = document.getElementById('theme-toggle');
	const html = document.documentElement;
	const sun = document.getElementById('icon-sun') as HTMLElement | null;
	const moon = document.getElementById('icon-moon') as HTMLElement | null;

	function applyTheme(theme: string) {
		html.setAttribute('data-theme', theme);
		localStorage.setItem('theme', theme);
		if (sun && moon) {
			sun.style.display = theme === 'light' ? 'none' : '';
			moon.style.display = theme === 'light' ? '' : 'none';
		}
	}

	applyTheme(localStorage.getItem('theme') || 'dark');

	toggle?.addEventListener('click', () => {
		applyTheme((html.getAttribute('data-theme') || 'dark') === 'light' ? 'dark' : 'light');
	});
</script>
